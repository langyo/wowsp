    "vue-router": "^4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5",
    "@vitejs/plugin-vue-jsx": "^4",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.2",
    "sass": "^1.100.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.1.8",
    "vue-tsc": "^2"
  }
