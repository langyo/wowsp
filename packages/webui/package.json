{
  "name": "@wowsp/webui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build-titlebar": "esbuild scripts/tauri-titlebar.ts --bundle --outfile=src/res/tauri-titlebar.js --format=iife --target=es2020",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^14",
    "echarts": "^6.1.0",
    "lucide-vue-next": "^1",
    "pinia": "^4",
    "three": "^0.184",
    "uuid": "^14",
    "vue": "^3",
    "vue-i18n": "^11",
    "vue-router": "^5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5",
    "@vitejs/plugin-vue-jsx": "^5",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.2",
    "sass": "^1.100.0",
    "typescript": "^7",
    "vite": "^8",
    "vitest": "^4.1.8",
    "vue-tsc": "^2"
  }
}
