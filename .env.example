# WoWSP Environment Variable Template
# Copy this file to .env and fill in the actual values.
# 复制此文件为 .env 并填写实际值
#
# Notes / 说明:
# - 大多数配置通过 WoWSP 设置面板维护，这里仅用于快速初始化与开发者覆盖
# - Most settings are managed via the WoWSP settings panel; this file is for
#   quick bootstrap and developer overrides only.

# =============================================================================
# Game Installation / 游戏安装位置
# =============================================================================
# 留空则启动时自动检测（注册表 + Steam manifest）
# Leave empty to auto-detect on launch (registry + Steam manifest)
WOWSP_GAME_PATH=
# 备选：指定 Steam 库目录（自动扫描 appmanifest_552990.acf）
# Optional: Steam library folder to scan for appmanifest_552990.acf
WOWSP_STEAM_LIBRARY=

# =============================================================================
# Replay Directory / 录像目录
# =============================================================================
# 默认 <游戏路径>/replays；可在此覆盖
# Defaults to <game_path>/replays; override here
WOWSP_REPLAY_DIR=

# =============================================================================
# Mock Mode / 模拟模式（前端开发）
# =============================================================================
# 启用 FastAPI mock 后端，让前端脱离游戏开发
# Enable the FastAPI mock backend for frontend development without the game
WOWSP_MOCK_MODE=false
# mock 后端端口 / mock backend port
WOWSP_MOCK_PORT=8787

# =============================================================================
# Overlay / 覆盖层（游戏内透明窗口模式）
# =============================================================================
# 按 Tab 触发截屏分析的对局名单检测热键
# Hotkey that triggers the screen-capture roster analysis
WOWSP_OVERLAY_HOTKEY=Tab
# 截屏分析的采样缩放（越小越快越省 CPU）
# Downscale factor for capture analysis (smaller = faster, less CPU)
WOWSP_OVERLAY_CAPTURE_SCALE=0.5

# =============================================================================
# Wargaming Public API（可选：查战绩）
# =============================================================================
# 留空则不查询在线战绩，仅做本地录像/阵容分析
# Leave empty to skip online stat lookups (local replay/roster analysis only)
WOWSP_WG_APPLICATION_ID=
# 默认区服 auto|ru|eu|na|asia|cn
# Default realm: auto|ru|eu|na|asia|cn
WOWSP_REALM=auto

# =============================================================================
# Logging / 日志
# =============================================================================
# RUST_LOG=wowsp=debug,info
