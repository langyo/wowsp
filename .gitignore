# Rust
/target/
**/*.rs.bk
# IDE
.idea/
.vscode/
.opencode/
*.swp
*.swo
*~
*.bak
*.tmp

# Node.js
node_modules/
dist/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
/logs/
/tmp/

# Operating system
.DS_Store
Thumbs.db

# Test coverage
/coverage/
**/__pycache__/
packages/app/tauri/gen/
.cache/

# Python venvs
.venv/
scripts/mock/.venv/

# Tauri icons are generated from docs/logo.svg by scripts/ensure_tauri_icons.py
# (via `cargo tauri icon`). They are build artifacts, not source — never commit.
packages/app/tauri/icons/*

# Logo sync cache (generated by scripts/sync_logo.py)
packages/webui/src/res/.logo-source-hash

# Transpiled shaders (generated from res/shaders/**/*.glsl + *.theme.toml by scripts/glsl_bundle.py)
packages/webui/.generated/

# WoWSP runtime data (detected game paths, parsed replays cache)
.wowsp-cache/

# Cargo lockfile (generated, not tracked)
Cargo.lock

# ZCode agent working dir
.zcode/

# Model conversion tool cache (downloaded by batch_bake.py)
/target/model-tools/
/target/model-tmp/

# Vendored external Rust projects (built in-tree but not part of our workspace)
packages/tools/wowsunpack-vendor/
